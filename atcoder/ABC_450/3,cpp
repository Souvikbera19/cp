#include <bits/stdc++.h>
using namespace std;
using ll = long long;

int main() {


    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    ll n,k;
    cin >> n >> k;
    vector<ll>r(n);
    for(int i =0;i<n;i++){
        ll x;
        cin >> x;
        r[i]=x%k;
    }
    sort(r.begin(),r.end());
    ll ans= 0;
    for(int i =1;i<n;i++){
        ans= max(ans,)
    }
    cout << ans << '\n';

    return 0;
}